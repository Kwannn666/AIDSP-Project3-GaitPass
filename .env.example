# Match this to the Jetson L4T/JetPack version.
# Check on Jetson with: cat /etc/nv_tegra_release
L4T_TAG=r35.4.1

APP_PORT=18080
CAMERA_SOURCE=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30
# onnx = YOLOv8-pose ONNX; tensorrt = TensorRT engine; hog = no-model baseline.
DETECTOR_MODE=onnx
MODEL_PATH=models/yolov8n-pose.onnx
DETECTOR_CONF=0.50
KEYPOINT_CONF=0.35
MIN_VALID_KEYPOINTS=5
MIN_BOX_AREA_RATIO=0.01

# 0 means raw frames are not saved by the app.
SAVE_RAW_FRAMES=0

AUTH_THRESHOLD=0.72
UNKNOWN_MARGIN=0.03
# Final identity smoothing. Accept is stricter when a track first becomes person_a;
# keep is looser so person_a does not flicker back to unknown every few frames.
AUTH_SMOOTHING_WINDOW=8
AUTH_ACCEPT_THRESHOLD=0.975
AUTH_KEEP_THRESHOLD=0.940
AUTH_ACCEPT_MARGIN=0.002
AUTH_KEEP_MARGIN=-0.005
TAILGATING_WINDOW_SEC=10.0
GATE_LINE_Y_RATIO=0.55
TAILGATING_NEAR_LINE_RATIO=0.18

# Optional alerting. Webhook sends JSON {"text": "...", "event": {...}}.
# Twilio sends SMS when all TWILIO_* values are set.
ALERT_ENABLED=0
ALERT_COOLDOWN_SEC=15
ALERT_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_TO=
